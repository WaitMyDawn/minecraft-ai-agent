# ============================================
# MAA 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# DeepSeek API Key (已弃用，默认为空, 用户可在 Web UI 中设置个人 Key)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# AES 加密密钥 — 用于加密存储用户的个人 API Key
# 生成方式: openssl rand -base64 32
MAA_ENCRYPTION_SECRET=change-me-to-a-random-string-at-least-32-chars

# CurseForge API Key (已弃用，空置)
CURSEFORGE_API_KEY=

# 沙盒基础服务器目录 (可选, 不配置则无法使用整合包校验功能)
# Windows 示例:
#   MAA_SANDBOX_DIR=D:\maa-base-server
# Debian/Linux 示例:
#   MAA_SANDBOX_DIR=/opt/maa/maa-base-server
MAA_SANDBOX_DIR=

# 是否允许公开注册 (内测期间建议设为 false)
# MAA_ALLOW_REGISTRATION=false
